# --- ML / DL Artifacts ---
checkpoints/
runs/              # TensorBoard logs
*.ckpt             # PyTorch checkpoints
*.pt               # PyTorch model files
*.pth              # PyTorch weights
*.h5               # Keras / TensorFlow models
*.pb               # TensorFlow protobuf
*.onnx             # ONNX models
*.tflite           # TensorFlow Lite models

# --- DVC ---
