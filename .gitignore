.venv/
env/
venv/
ENV/

# --- Jupyter / Notebooks ---
.ipynb_checkpoints/
*.ipynb.json

# --- VS Code ---
.vscode/
*.code-workspace

# --- OS / Editor Files ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

